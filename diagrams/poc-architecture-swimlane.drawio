        <mxCell id="arr_pg_rca" value="run history" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#16A34A;strokeWidth=1.5;exitX=0.3;exitY=0;entryX=0.4;entryY=1;fontSize=9;fontColor=#14532D;" edge="1" source="pg_metrics" target="af_rca" parent="1">
